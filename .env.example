# Server port (default: 5001)
PORT=5001

# Google Gemini API key — used server-side so clients don't need to supply it.
# Obtain from https://aistudio.google.com/app/apikey
GOOGLE_GENAI_API_KEY=your_gemini_api_key_here

# Comma-separated list of allowed CORS origins.
# Use * to allow all origins (not recommended for production).
# Example: https://myapp.com,http://localhost:5173
ALLOWED_ORIGINS=*

# Pikalytics regulation slug used in the scraper URL.
# Update this as new VGC regulations become active.
# Example values: gen9vgc2024regf, gen9vgc2025regg, gen9vgc2025regh
PIKALYTICS_REGULATION=gen9vgc2024regf
